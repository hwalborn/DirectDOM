# Backend
PORT=3001
DATABASE_URL=postgresql://directdom:directdom@localhost:5432/directdom
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production

# Local ferrum checkout for mcp-dibs-css (defaults to ../ferrum next to DirectDOM)
# FERRUM_ROOT=/Users/you/projects/ferrum

# LLM (optional — mock used when no API key for the selected provider)
LLM_PROVIDER=openai
LLM_MODEL=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Google OAuth (Docs API — one of the auth options below)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
# GOOGLE_REFRESH_TOKEN=          # OAuth refresh token (for yarn update-prd)
# GOOGLE_ACCESS_TOKEN=           # One-off access token
# GOOGLE_SERVICE_ACCOUNT_JSON=   # Inline JSON or path to service account key
# PRD_DOC_ID=                    # Override default DirectDOM PRD doc ID

# JIRA
JIRA_BASE_URL=https://1stdibs.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# GitHub
GITHUB_TOKEN=
GITHUB_ORG=1stdibs
# GITHUB_CREATE_PR=false          # Push branch only; skip opening draft PR(s)

# Google Docs template
GOOGLE_DOC_TEMPLATE_ID=

# Extension (build-time)
VITE_API_URL=http://localhost:3001
